<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">My Movie Lists</h1>
    <%= link_to "New list", new_list_path, class: "btn btn-primary" %>
  </div>

  <div class="row g-3">
    <% @lists.each do |list| %>
      <div class="col-12 col-md-6 col-lg-4">
        <%= link_to list_path(list), class: "text-decoration-none" do %>
          <div class="card h-100 shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between">
              <h2 class="h5 text-dark mb-0"><%= list.name %></h2>
              <span class="badge text-bg-dark"><%= list.movies.count %> movies</span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
