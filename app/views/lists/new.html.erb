<div class="container py-5" style="max-width: 640px;">
  <h1 class="mb-4">Create a new list</h1>

  <%= simple_form_for @list do |f| %>
    <%= f.input :name, placeholder: "Drama, Comedy, Classic..." %>
    <%= f.submit "Create list", class: "btn btn-primary" %>
  <% end %>

  <div class="mt-3">
    <%= link_to "Back to lists", lists_path, class: "btn btn-outline-secondary" %>
  </div>
</div>
